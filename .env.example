# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Required: API key for the hosted Ollama model (https://ollama.com)
OLLAMA_API_KEY=

# Optional overrides -- sensible defaults are already set in config.py
# OLLAMA_HOST=https://ollama.com
# MODEL=gpt-oss:120b

# Optional: override where each grade's source PDFs live for ingestion.
# Defaults to ./data/gradeN if not set.
# GRADE_6_SOURCE_DIR=./data/grade6
# GRADE_7_SOURCE_DIR=./data/grade7
# PDF_SOURCE_DIR=./data/grade8
# GRADE_9_SOURCE_DIR=./data/grade9
# GRADE_10_SOURCE_DIR=./data/grade10
